# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node (legacy keepa)
node_modules/
package-lock.json
npm-debug.log*

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artefacts
dist/
build/
services/amazon-fba-fees-mcp/dist/
services/amazon-fba-fees-mcp/build/

# Claude Code / MCP session-local state
.claude/
.mcp.json
.playwright-mcp/

# Engine run outputs — operator-local artefacts, regenerated per run
fba_engine/data/strategies/

# Local pre-merge backups created when reconciling PRDs / docs
*.local-pre-merge-backup

# Data — gitignored except for the bits we want to track
fba_engine/data/pricelists/*/raw/
fba_engine/data/pricelists/*/results/
fba_engine/data/niches/*/working/
fba_engine/data/niches/*/*.xlsx
fba_engine/data/niches/*/*.csv

# Allow specific data files we DO want to track
!fba_engine/data/pricelists/*/raw/.gitkeep
!fba_engine/data/pricelists/*/results/.gitkeep
!fba_engine/data/niches/*/.gitkeep

# Exclusions list (applies across niches — DO track this)
!fba_engine/data/exclusions.csv

# Legacy keepa working data
fba_engine/_legacy_keepa/data/

# Runtime
*.log
*.pid

# MCP persistent cache (SP-API responses, ASIN→{restrictions,fees,catalog,...})
.cache/

# Credentials — must NEVER be committed
# If you find any of these patterns already tracked in git history, you must rotate
# the credential AND scrub from history (git filter-repo or BFG)
.env
.env.*
!.env.example
credentials/
secrets/
*credential*.json
*secret*.json
*service*account*.json
*service_account*
google-service-account*.json
service_account.json
*-key.json
*.pem
*.key
id_rsa*
.aws/
